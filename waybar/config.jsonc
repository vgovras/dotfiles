// -*- mode: jsonc -*-
// Waybar for Sway ÔÇö mimics the default swaybar look (flat dark bottom bar),
// with richer icons/colors on the right since waybar allows it.
// Icons written as \uXXXX to avoid editors/linters stripping PUA glyphs.
{
  "layer": "top",
  "position": "bottom",
  "height": 22,
  "spacing": 0,
  "reload_style_on_change": true,

  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": [],
  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "cpu",
    "memory",
    "temperature",
    "power-profiles-daemon",
    "battery",
    "custom/language",
    "clock",
    "custom/power",
  ],

  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
  },

  "sway/mode": {
    "format": "´ï▒ {}",
  },

  "custom/language": {
    "exec": "swaymsg -t get_inputs | grep -m1 '\"xkb_active_layout_name\"' | sed 's/.*\": \"\\(..\\).*/\\1/' | tr '[:lower:]' '[:upper:]'",
    "interval": 1,
    "format": "´ä£ {}",
    "tooltip": false,
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
  },

  "clock": {
    "format": "´Çù {:%I:%M %p}",
    "format-alt": "´ü│ {:%a %d.%m  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "today": "<span color='#ffffff'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },

  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon} {percent}%",
    "format-icons": ["´åå", "´åà"],
    "tooltip-format": "Brightness: {percent}%",
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
  },

  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "´Çª",
    "format-bluetooth": "´èö {icon} {volume}%",
    "format-bluetooth-muted": "´èö ´Çª",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ÇÑ",
      "headset": "´ÇÑ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´Çª", "´Çº", "´Ç¿"],
    },
    "tooltip-format": "{desc}: {volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
  },

  "battery": {
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âº {capacity}%",
    "format-plugged": "´çª {capacity}%",
    "format-full": "´ëÇ {capacity}%",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "tooltip-format": "{timeTo} ÔÇó {power}W",
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}",
    "format-icons": {
      "default": "´ïø",
      "performance": "´äÁ",
      "balanced": "´ëÄ",
      "power-saver": "´ü¼",
    },
  },

  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 85,
    "format": "´ïë {temperatureC}┬░C",
    "format-critical": "´ïç {temperatureC}┬░C",
    "tooltip-format": "CPU temperature: {temperatureC}┬░C",
  },

  "cpu": {
    "interval": 2,
    "states": {
      "warning": 75,
      "critical": 90,
    },
    "format": "´Æ╝ {usage}%",
    "tooltip-format": "CPU load: {usage}% ÔÇó {load} avg",
  },

  "memory": {
    "interval": 5,
    "states": {
      "warning": 75,
      "critical": 90,
    },
    "format": "¾░ÿÜ {percentage}%/{swapPercentage}%",
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G ({swapPercentage}%)",
  },

  "tray": {
    "icon-size": 14,
    "spacing": 6,
  },

  "custom/power": {
    "format": "´Çæ",
    "tooltip": false,
    "on-click": "~/.config/waybar/power-menu.sh",
  },
}
